# App
NODE_ENV=development
PORT=3000
APP_NAME=AV Dispatch & Scope Intelligence Portal
APP_TIMEZONE=America/New_York

# Data
DATA_SOURCE=excel
EXCEL_WORK_ORDERS_OPEN_CASES_FILE=./data/current/work-orders-open-cases.xlsx
EXCEL_DATA_LEGEND_FILE=./Data Legend.xlsx
EXCEL_KEYWORD_CONFIG_FILE=./NextSteps_Keyword_Config.xlsx
EXCEL_BOM_FILE=./data/current/bom.xlsx

# Auth
AUTH_MODE=local
AUTH_SHARED_PASSWORD=change_me
AUTH_SESSION_SECRET=replace_with_a_long_random_string

# AI
OPENAI_API_KEY=your_key_here
AI_MODEL=gpt-5.4-mini

# External intelligence
WEATHER_USER_AGENT=AVDispatchScopePortal (your-email@company.com)
WEATHER_CONTACT_EMAIL=your-email@company.com
TRAFFIC_API_KEY=your_key_here
